# ═══════════════════════════════════════════════════════════════
# Claude Telegram Bot Configuration
# ═══════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Comma-separated Telegram user IDs allowed to use the bot
# Get yours by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# Anthropic API key (required for Agent SDK)
ANTHROPIC_API_KEY=sk-ant-...

# ── Workspace ────────────────────────────────────────────────
# Root directory for project picker
# Default: $HOME
# WORKSPACE_DIR=/home/username/projects

# ── Claude Agent SDK ─────────────────────────────────────────
# Use SDK bundled executable for agent queries (true/false)
# CLAUDE_USE_BUNDLED_EXECUTABLE=true

# SDK log level: off | basic | verbose | trace
# CLAUDE_SDK_LOG_LEVEL=basic

# Append a reasoning summary to each response (true/false)
# CLAUDE_REASONING_SUMMARY=true

# ── Bot Behavior ─────────────────────────────────────────────
# Bot display name
# BOT_NAME=Claude Telegram

# Bot run mode (dev/prod)
# BOT_MODE=prod

# "streaming" = live-updating messages, "wait" = send when complete
# STREAMING_MODE=streaming

# Max characters per message chunk (Telegram limit is 4096)
# MAX_MESSAGE_LENGTH=4096

# Auto-approve all Claude tool permissions (single trusted user)
# DANGEROUS_MODE=true

# Max iterations for /loop command
# MAX_LOOP_ITERATIONS=5

# Enable terminal-style UI by default (animated spinners, tool status)
# TERMINAL_UI_DEFAULT=true

# Max image file size in MB
# IMAGE_MAX_FILE_SIZE_MB=20

# Comma-separated group IDs (optional, for group chat support)
# ALLOWED_GROUP_IDS=
